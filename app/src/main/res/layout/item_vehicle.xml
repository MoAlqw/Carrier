<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_marginBottom="10dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="0dp"
        app:cardCornerRadius="12dp"
        app:strokeWidth="0.5dp"
        app:strokeColor="?attr/colorOutline">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="15dp">

            <ImageView
                android:id="@+id/ivCargo"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/cargo"
                android:background="@drawable/bg_plate_light_blue"
                android:padding="5dp"
                android:contentDescription="@string/flights"
                app:tint="@color/blue"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:id="@+id/tvBrandWithModel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/Title"
                tools:text="MAN TGS"
                android:layout_marginStart="20dp"
                app:layout_constraintStart_toEndOf="@id/ivCargo"
                app:layout_constraintTop_toTopOf="@id/ivCargo" />

            <TextView
                android:id="@+id/tvPlateWithFuel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="784 HHH 01 · 35 л/100 км"
                android:layout_marginStart="20dp"
                app:layout_constraintStart_toEndOf="@id/ivCargo"
                app:layout_constraintBottom_toBottomOf="@id/ivCargo" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>